{
  "version": 2,
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/frames/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/assets/water-trail.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://cdn.tailwindcss.com 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https: data:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://api.emailjs.com https://n8n.victor-ia.com.mx https://n8n.srv1013903.hstgr.cloud https://formsubmit.co" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://cdn.tailwindcss.com https://vtc-capacitacion-deploy.vercel.app https://victor-ia-brain-tracker.vercel.app 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https: data:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://api.emailjs.com https://n8n.victor-ia.com.mx https://n8n.srv1013903.hstgr.cloud https://formsubmit.co https://vtc-capacitacion-deploy.vercel.app" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/404", "destination": "/404.html" },
    { "source": "/capacitacion-timeshare", "destination": "/capacitacion-timeshare-frame.html" },
    { "source": "/capacitacion-timeshare.html", "destination": "/capacitacion-timeshare-frame.html" }
  ],
  "redirects": [
    { "source": "/propuesta", "destination": "/propuesta-central-alarmas", "permanent": false },
    { "source": "/archive/:path*", "destination": "/", "permanent": false },
    { "source": "/agenda",         "destination": "/agendar-videollamada", "permanent": false },
    { "source": "/blog",           "destination": "/blog/index.html",     "permanent": false },
    { "source": "/propuestas/central-alarmas", "destination": "/propuestas/central-alarmas-eduardo-pimentel", "permanent": false },
    { "source": "/wdc", "destination": "/propuestas/wdc-propuesta", "permanent": false },
    { "source": "/propuestas/wdc", "destination": "/propuestas/wdc-propuesta", "permanent": false }
  ]
}